<div class="max-w-5xl mx-auto mt-10 px-4">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-extrabold text-gray-900">Trilhas de Aprendizado 📚</h1>
    <%= link_to "Voltar", root_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @modules.each do |mod| %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col">
        <h2 class="text-xl font-bold text-gray-800 mb-2"><%= mod.title %></h2>
        <p class="text-gray-600 mb-6 flex-grow"><%= mod.description %></p>

        <%= link_to "Acessar Módulo", course_module_path(mod), class: "w-full py-2 px-4 bg-blue-50 text-blue-700 font-bold rounded-lg hover:bg-blue-100 transition-colors text-center" %>
      </div>
    <% end %>
  </div>
</div>