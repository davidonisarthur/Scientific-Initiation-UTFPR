<div class="max-w-4xl mx-auto mt-10 px-4 pb-12">
  <nav class="mb-8">
    <%= link_to "← Voltar para a lista de módulos", course_modules_path, class: "text-blue-600 hover:text-blue-800 font-medium transition-colors" %>
  </nav>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-8">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">
      <%= @module.title %>
    </h1>
    <p class="text-xl text-gray-600 leading-relaxed">
      <%= @module.description %>
    </p>
  </div>

  <div class="space-y-6">
    <h2 class="text-2xl font-bold text-gray-800 border-b border-gray-200 pb-2 mb-6">
      Questões de Fixação (<%= @questions.count %>)
    </h2>

    <% if @questions.any? %>
      <% @questions.each_with_index do |question, index| %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col md:flex-row">

          <div class="md:w-1/3 bg-gray-100 flex-shrink-0">
            <% if question.video_libras_url.present? %>
              <div class="aspect-w-16 aspect-h-9 h-full">
                <iframe src="<%= question.video_libras_url %>" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="w-full h-full min-h-[200px] object-cover"></iframe>
              </div>
            <% else %>
              <div class="flex items-center justify-center h-full min-h-[200px] text-gray-400">
                <span>Sem vídeo disponível</span>
              </div>
            <% end %>
          </div>

          <div class="p-6 md:w-2/3 flex flex-col justify-center">
            <h3 class="text-lg font-bold text-gray-900 mb-4">
              <span class="text-blue-600 mr-2"><%= index + 1 %>)</span><%= question.question_text %>
            </h3>

            <div class="space-y-3">
              <div class="p-3 border rounded-lg bg-gray-50 text-gray-700"><span class="font-bold mr-2 text-gray-900">A.</span><%= question.option_a %></div>
              <div class="p-3 border rounded-lg bg-gray-50 text-gray-700"><span class="font-bold mr-2 text-gray-900">B.</span><%= question.option_b %></div>
              <div class="p-3 border rounded-lg bg-gray-50 text-gray-700"><span class="font-bold mr-2 text-gray-900">C.</span><%= question.option_c %></div>
              <div class="p-3 border rounded-lg bg-gray-50 text-gray-700"><span class="font-bold mr-2 text-gray-900">D.</span><%= question.option_d %></div>
            </div>

            <button class="mt-6 w-full py-2 px-4 border border-blue-600 text-blue-600 font-bold rounded-lg hover:bg-blue-50 transition-colors">
              Responder Questão
            </button>
          </div>

        </div>
      <% end %>
    <% else %>
      <div class="bg-blue-50 border-l-4 border-blue-400 p-4 rounded-r-lg">
        <p class="text-sm text-blue-700 font-medium">Nenhuma questão cadastrada neste módulo ainda.</p>
      </div>
    <% end %>
  </div>
</div>