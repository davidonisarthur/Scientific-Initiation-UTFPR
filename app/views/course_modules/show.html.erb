<div class="max-w-4xl mx-auto mt-10 px-4">
  <nav class="mb-8">
    <%= link_to "← Voltar para a lista de módulos", course_modules_path, class: "text-blue-600 hover:text-blue-800 font-medium transition-colors" %>
  </nav>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 mb-8">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">
      <%= @module.title %>
    </h1>
    <p class="text-xl text-gray-600 leading-relaxed">
      <%= @module.description %>
    </p>
  </div>

  <div class="space-y-6">
    <h2 class="text-2xl font-bold text-gray-800 border-b pb-2">Questões do Módulo</h2>

    <div class="bg-blue-50 border-l-4 border-blue-400 p-4 rounded-r-lg">
      <div class="flex">
        <div class="ml-3">
          <p class="text-sm text-blue-700 font-medium">
            Em breve: Aqui aparecerão as questões com vídeos em Libras! 🎥🤟
          </p>
        </div>
      </div>
    </div>
  </div>
</div>